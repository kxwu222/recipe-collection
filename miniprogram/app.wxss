}

.mode-tab.active {
  background: var(--primary);
  color: white;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

.btn-invite {
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  max-width: 200rpx;
  height: auto;
  min-height: 75rpx;
  letter-spacing: 0.5rpx;
}
