  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.step-input-wrapper {
  flex: 1;
  display: flex;
}

.step-textarea {
  flex: 1;
  min-height: 160rpx;
  height: 160rpx;
  font-size: 30rpx;
  padding: 16rpx;
  line-height: 1.5;
  margin: 0;
  background: var(--white);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.step-content {
