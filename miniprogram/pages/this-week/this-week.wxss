/* This-week page styles */

.opacity-50 {
  opacity: 0.5;
}

.to-buy-item {
  padding: 16rpx 24rpx;
}

.mode-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

/* Weekly recipe card */
.week-recipe-card {
  display: flex;
  align-items: center;
  background: var(--surface);
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  overflow: hidden;
  padding: 4rpx 36rpx 4rpx 4rpx;
}

.week-recipe-content {
  display: flex;
  flex: 1;
  align-items: center;
  padding: 12rpx;
  gap: 16rpx;
}

.week-recipe-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: rgba(212, 165, 116, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0rpx 20rpx 0rpx 10rpx;
}

.week-recipe-image image {
  width: 100%;
  height: 100%;
}

.week-recipe-info {
  flex: 1;
  overflow: hidden;
}

.week-recipe-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.week-recipe-tags {
  display: flex;
  gap: 8rpx;
}

.week-tag {
  font-size: 20rpx;
  font-weight: 400;
  color: var(--primary);
  background: rgba(212, 165, 116, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 9999rpx;
}

.week-recipe-delete {
  padding: 12rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.week-recipe-delete:active {
  color: var(--error);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: var(--surface);
  border-radius: 24rpx;
  padding: 32rpx;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 28rpx;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  background: var(--white);
  box-sizing: border-box;
}

.modal-input-placeholder {
  color: var(--text-muted);
}

.modal-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  line-height: 80rpx;
  text-align: center;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  background: var(--white);
  color: var(--text-primary);
  border: 1rpx solid var(--border);
}

.modal-btn-confirm {
  background: var(--primary) !important;
  color: var(--white) !important;
}

.btn.btn-primary.btn-sm {
  border-radius: 20rpx;
  min-width: 20rpx;
  padding: 10rpx 30rpx;
  margin-top: 20rpx;
  color: #4d3602;
  border: solid 1rpx #4d3602;
  background-color: var(--surface);
  box-shadow: 1px 1px 0px 0px var(--primary);
}

/* Date Range Selector */
.date-range-section {
  background: var(--surface);
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  border: 1rpx solid var(--border);
  align-items: center;
  justify-content: center;
}

.date-range-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 4rpx;
}



.date-range-toggle {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding-right: 20rpx;
}

.toggle-text {
  font-size: 26rpx;
  color: var(--text-muted);
}

.toggle-icon {
  font-size: 20rpx;
  color: var(--text-muted);
}

.date-range-presets {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  margin-bottom: 26rpx;
  padding-left: 10rpx;
}

.date-preset {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 9999rpx;
  color: var(--text-muted);
  background: var(--background);
}

.date-preset.active {
  color: var(--white);
  background: var(--primary);
}

.date-picker-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  margin-bottom: 18rpx;
  padding-left: 10rpx;
}

.date-picker {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  padding: 0 12rpx;
  background: var(--white);
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
}

.date-picker-text {
  font-size: 26rpx;
  color: var(--text-primary);
  padding-left: 10rpx;
}

.date-separator {
  color: var(--text-muted);
}



.date-display-text {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  padding: 6rpx 10rpx 4rpx 10rpx;
  border-bottom: 0.5rpx dashed #cccccc;
  margin-left: 4px;
}

.date-range-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.date-range-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-muted);
}

.date-range-presets {
  display: flex;
  gap: 8rpx;
}

.date-preset {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 9999rpx;
  color: var(--text-muted);
  background: var(--background);
}

.date-preset.active {
  color: var(--white);
  background: var(--primary);
}

.date-picker-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-picker {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--white);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
}

.date-picker-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  padding: 16rpx;
}

.date-separator {
  color: var(--text-muted);
}

.date-display {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.date-display-text {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}