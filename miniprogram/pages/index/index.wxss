/* Index page styles */

/* Quick Actions Layout */
.quick-actions-row {
  display: flex;
  gap: 20rpx;
}

.quick-actions-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  flex: 1;
}

.quick-action-card {
  flex: 1;
  background: var(--surface);
  border-radius: 24rpx;
  padding: 32rpx;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.quick-action-card.tall {
  width: 40%;
  flex-direction: column;
  justify-content: center;
  padding: 40rpx 24rpx;
}

.quick-action-card:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.quick-action-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.quick-action-cta {
  margin-top: 24rpx;
  background: #8B6344;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: white;
  font-size: 30rpx;
  font-weight: 600;
}

.quick-action-cta:active {
  opacity: 0.85;
}

/* Recent Recipes - Horizontal Scroll */
.recipe-scroll-container {
  width: 100%;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.recipe-scroll-container::-webkit-scrollbar {
  display: none;
}

.recipe-scroll-inner {
  display: flex;
  gap: 20rpx;
  padding: 8rpx 0;
  white-space: nowrap;
}

.recipe-mini-card {
  display: inline-flex;
  flex-direction: column;
  width: 300rpx;
  min-width: 300rpx;
  background: var(--surface);
  border-radius: 20rpx;
  padding: 20rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  vertical-align: top;
}

.recipe-mini-card:active {
  opacity: 0.85;
}

.recipe-mini-image {
  height: 160rpx;
  background: rgba(212, 165, 116, 0.08);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.recipe-mini-content {
  white-space: normal;
}

.recipe-mini-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.recipe-mini-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.mini-tag {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--primary);
  background: rgba(212, 165, 116, 0.12);
  padding: 6rpx 14rpx;
  border-radius: 9999rpx;
}

.text-primary.text-sm.view {
  color: var(--text-primary);
  border: 1rpx solid var(--text-primary);
  padding: 6rpx 16rpx 6rpx 16rpx;
  box-shadow: 1px 1px 0px 0px var(--text-primary);
}

.text-primary.text-sm {
  border: 1rpx solid var(--primary);
  background-color: var(--surface);
  border-radius: 20rpx;
  padding: 10rpx;
  margin: 4rpx;
  box-shadow: 1px 1px 0px 0px var(--primary);
}