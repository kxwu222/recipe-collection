/* Add Recipe Page Styles */

/* Card Override */
.card {
  overflow: visible;
  padding: 32rpx;
}

/* Page Header */
.page-header {
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* Text Tab Header */
.text-tab-header {
  margin-bottom: 20rpx;
}

.text-tab-header .form-label {
  padding-left: 0;
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.text-tab-header .import-url-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.4;
}

/* Recipe Textarea */
.recipe-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: var(--background);
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  box-sizing: border-box;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 10;
}

.recipe-textarea:focus {
  border-color: #8B6344;
}

/* Source Link Row */
.source-link-row {
  margin-top: 16rpx;
  margin-bottom: 24rpx;
}

.source-link-input {
  font-size: 26rpx;
  padding: 16rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  background: var(--background);
}

/* Block Button */
.btn-block {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  box-sizing: border-box; 
}

.btn-loading {
  opacity: 0.8;
  pointer-events: none;
}

.btn-loading-icon {
  width: 40rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.btn-loading-icon::before,
.btn-loading-icon::after,
.btn-loading-icon view {
  width: 8rpx;
  height: 8rpx;
  background: #fff;
  border-radius: 50%;
  animation: loading-dot 1.2s ease-in-out infinite;
}

.btn-loading-icon::before {
  content: '';
  animation-delay: 0s;
}

.btn-loading-icon view {
  animation-delay: 0.2s;
}

.btn-loading-icon::after {
  content: '';
  animation-delay: 0.4s;
}

@keyframes loading-dot {
  0%, 80%, 100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  40% {
    opacity: 1;
    transform: scale(1.2);
  }
}

/* Dropdown */
.dropdown {
  position: relative;
}

.dropdown-trigger {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 48rpx;
}

.dropdown-list {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  margin-top: 12rpx;
  overflow: hidden;
  z-index: 100;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
  max-height: 400rpx;
  overflow-y: auto;
}

.dropdown-item {
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background 0.2s;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background: rgba(139, 99, 68, 0.1);
}

.dropdown-item.selected {
  color: #8B6344;
  font-weight: 600;
}

/* Image Upload Area */
.image-upload-area {
  width: 100%;
  height: 240rpx;
  border: 2rpx dashed var(--border);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface);
  overflow: hidden;
  position: relative;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.upload-placeholder image {
  width: 40rpx;
  height: 40rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
}

.image-delete-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

/* Ingredient Row */
.ingredient-row {
  background: var(--background);
  border-radius: 12rpx;
  padding: 10rpx;
}

.ingredient-fields {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ingredient-index {
  width: 40rpx;
  text-align: center;
  font-size: 22rpx;
}

.ingredient-name {
  flex: 2;
}

.ingredient-qty {
  flex: 1;
}

.ingredient-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Step Row */
.step-row {
  background: var(--background);
  border-radius: 12rpx;
  padding: 12rpx;
  overflow: visible;
}

.step-content {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.step-input-wrapper {
  flex: 1;
  min-height: 0;
  max-height: none;
  overflow: visible;
}

.step-content {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  margin-bottom: 20rpx;
  overflow: visible;
}

.step-number {
  width: 40rpx;
  height: 40rpx;
  background: #8B6344;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-top: 12rpx;
}

.step-textarea {
  width: 100%;
  min-height: 0;
  max-height: none;
  padding: 16rpx;
  border-radius: 12rpx;
  background: var(--background);
  border: 2rpx solid var(--border);
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--text-primary);
  box-sizing: border-box;
  word-wrap: break-word;
  white-space: pre-wrap;
}

.step-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 8rpx;
}

/* Form Group Spacing */
.form-group {
  margin-bottom: 28rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

/* Section Header */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-hint {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* Add Button */
.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  background: transparent;
}

.btn-outline:active {
  background: rgba(139, 99, 68, 0.05);
}

.btn-sm {
  font-size: 26rpx;
  padding: 16rpx 20rpx;
}

/* Apply Button */
.mt-4 {
  margin-top: 40rpx;
}

.mb-3 {
  margin-bottom: 20rpx;
}

.mb-4 {
  margin-bottom: 32rpx;
}
