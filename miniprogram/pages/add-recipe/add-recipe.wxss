/* Add Recipe Page Styles */

/* Card Override */
.card {
  overflow: visible;
}

/* Page Header */
.page-header {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.feature-badge {
  align-items: center;
  gap: 6rpx;
  background: rgba(139, 99, 68, 0.1);
  color: #8B6344;
  padding: 6rpx 20rpx 6rpx 0rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* Example Hint */
.example-hint {
  background: rgba(139, 99, 68, 0.06);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.example-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #8B6344;
  flex-shrink: 0;
}

.example-text {
  font-size: 22rpx;
  color: var(--text-muted);
  flex: 1;
  word-break: break-all;
}

/* Recipe Textarea */
.recipe-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 20rpx;
  background: var(--background);
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--text-primary);
  box-sizing: border-box;
  margin-bottom: 0;
}

.recipe-textarea:focus {
  border-color: #8B6344;
}

/* Source URL Input */
.source-url-input {
  margin-top: 16rpx;
  margin-bottom: 40rpx;
}

.source-url-input .form-label {
  padding-left: 0;
}

.source-url-input .input-field {
  font-size: 28rpx;
  line-height: 1.5;
  border-radius: 12rpx;
  padding: 20rpx;
  border: 2rpx solid var(--border);
  background: var(--background);
}

/* Block Button */
.btn-block {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 12rpx;
  box-sizing: border-box; 
}

/* Dropdown */
.dropdown {
  position: relative;
}

.dropdown-trigger {
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 44rpx;
}

.dropdown-list {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  margin-top: 8rpx;
  overflow: hidden;
  z-index: 100;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  max-height: 400rpx;
  overflow-y: auto;
}

.dropdown-item {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background 0.2s;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background: rgba(139, 99, 68, 0.1);
}

.dropdown-item.selected {
  color: #8B6344;
  font-weight: 600;
}

/* Image Upload Area */
.image-upload-area {
  width: 100%;
  height: 200rpx;
  border: 2rpx dashed var(--border);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface);
  overflow: hidden;
  position: relative;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
}

.image-delete-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

/* Ingredient Row */
.ingredient-row {
  background: var(--background);
  border-radius: 12rpx;
  padding: 12rpx;
}

.ingredient-fields {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ingredient-index {
  width: 40rpx;
  text-align: center;
}

.ingredient-name {
  flex: 2;
}

.ingredient-qty {
  flex: 1;
}

.ingredient-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Step Row */
.step-row {
  background: var(--background);
  border-radius: 12rpx;
  padding: 12rpx;
}

.step-content {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.step-number {
  width: 40rpx;
  height: 40rpx;
  background: #8B6344;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.step-input-wrapper {
  flex: 1;
}

.step-textarea {
  min-height: 80rpx;
  padding: 16rpx;
}

.step-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 8rpx;
}
