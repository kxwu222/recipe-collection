/* Recipes page styles */

/* Add recipe button */
.add-recipe-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  background: #8B6344;
  border-radius: 9999rpx;
  color: white;
  font-size: 26rpx;
  font-weight: 600;
}

.add-recipe-btn:active {
  opacity: 0.85;
}

/* Filter chips */
.filter-scroll {
  white-space: nowrap;
  padding: 4rpx 0;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  margin-right: 8rpx;
  border-radius: 99rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-primary);
  background: var(--surface);
  border: 1rpx solid var(--border);
  white-space: nowrap;
  min-width: 46rpx;
  justify-content: center;
}

.filter-chip.active {
  background: var(--primary);
  border-color: var(--primary);
  color: var(--white);
}

/* Recipe card overrides for recipes page */
.recipe-card:active {
  opacity: 0.85;
}

.recipe-card-image-img {
  width: 100%;
  height: 100%;
}

.tag {
  font-size: 20rpx;
  font-weight: 400;
  color: var(--primary);
  background: rgba(212, 165, 116, 0.12);
  padding: 2rpx 10rpx;
  border-radius: 9999rpx;
}
