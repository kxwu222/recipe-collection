<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="text-3xl font-bold text-foreground mb-4">{{t.settings}}</view>
  </view>

  <!-- User Info -->
  <view wx:if="{{isAuthenticated && user}}" class="card mb-4">
    <view class="flex items-center justify-between">
      <view>
        <view class="section-title">{{t.user}}</view>
        <view class="text-xl font-bold text-foreground">{{user.name || t.user}}</view>
      </view>
      <view class="logout-pill text-sm" bindtap="handleLogout">
        <text>{{t.logout}}</text>
      </view>
    </view>
  </view>

  <!-- Login Prompt (when not authenticated) -->
  <view wx:if="{{!isAuthenticated}}" class="card mb-4">
    <view class="flex items-center justify-between">
      <view>
        <view class="section-title">{{t.user}}</view>
        <view class="text-lg text-muted">未登录</view>
      </view>
    </view>
  </view>

  <!-- Household & Stats -->
  <view wx:if="{{isAuthenticated}}" class="mb-4">
    <!-- Household Card -->
    <view class="card mb-4" bindtap="goToFamily">
      <view class="flex items-center justify-between">
        <view>
          <view class="section-title">{{t.family}}</view>
          <view class="text-lg font-bold text-foreground">{{household.name || t.noHousehold}}</view>
        </view>
        <view class="text-primary text-sm">{{t.viewMembers}}</view>
      </view>
    </view>

    <!-- Recipe Count -->
    <view class="card">
      <view class="section-title">{{t.totalRecipes}}</view>
      <view class="text-3xl font-bold text-primary">{{recipeCount}}</view>
    </view>
  </view>

  <!-- Custom Filters Management -->
  <view class="card mb-4">
    <view class="section-title">修改菜谱分类</view>

    <!-- Cooking Methods -->
    <view class="manage-section" bindtap="toggleMethodSection">
      <view class="manage-header">
        <text class="manage-label">{{t.cookingMethod}}</text>
        <image src="/assets/images/{{showMethodSection ? 'chevron-up' : 'chevron-down'}}.png" class="manage-chevron"></image>
      </view>
    </view>
    <view wx:if="{{showMethodSection}}" class="manage-body">
      <view class="tag-list">
        <view wx:for="{{cookingMethods}}" wx:key="id" class="tag-item">
          <text class="tag-text">{{item.label}}</text>
          <view class="tag-remove" data-id="{{item.id}}" data-label="{{item.label}}" catchtap="deleteCookingMethod">
            <image src="/assets/images/close-red.png" style="width: 20rpx; height: 20rpx;"></image>
          </view>
        </view>
      </view>
      <view class="manage-add" bindtap="addCookingMethod">
        <image src="/assets/images/plus-primary.png" style="width: 22rpx; height: 22rpx;"></image>
        <text>添加</text>
      </view>
    </view>

    <!-- Dish Types -->
    <view class="manage-section" bindtap="toggleTypeSection">
      <view class="manage-header">
        <text class="manage-label">{{t.dishType}}</text>
        <image src="/assets/images/{{showTypeSection ? 'chevron-up' : 'chevron-down'}}.png" class="manage-chevron"></image>
      </view>
    </view>
    <view wx:if="{{showTypeSection}}" class="manage-body">
      <view class="tag-list">
        <view wx:for="{{dishTypes}}" wx:key="id" class="tag-item">
          <text class="tag-text">{{item.label}}</text>
          <view class="tag-remove" data-id="{{item.id}}" data-label="{{item.label}}" catchtap="deleteDishType">
            <image src="/assets/images/close-red.png" style="width: 20rpx; height: 20rpx;"></image>
          </view>
        </view>
      </view>
      <view class="manage-add" bindtap="addDishType">
        <image src="/assets/images/plus-primary.png" style="width: 22rpx; height: 22rpx;"></image>
        <text>添加</text>
      </view>
    </view>
  </view>

  <!-- Login Button (when not authenticated) -->
  <view wx:if="{{!isAuthenticated}}" class="login-btn" bindtap="goToLogin">
    <text>{{t.login}}</text>
  </view>

</view>
