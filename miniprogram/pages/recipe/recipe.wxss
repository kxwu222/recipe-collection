/* Recipe page styles */

/* Notes textarea alignment */
.notes-textarea {
  min-height: 44rpx;
  padding: 12rpx 16rpx;
  border-radius: 24rpx;
  line-height: 1.4;
}

/* Step textarea */
.step-textarea {
  min-height: 44rpx;
  padding: 12rpx 16rpx;
  line-height: 1.4;
}

/* Header layout */
.recipe-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.recipe-header-left {
  flex: 1;
  min-width: 0;
}

.recipe-header-right {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: flex-end;
  max-width: 220rpx;
  padding-top: 8rpx;
}

.header-chip {
  background: rgba(139, 99, 68, 0.08);
  color: #8B6344;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
  line-height: 1.3;
}

/* Servings adjuster */
.servings-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--surface);
  padding: 18rpx 36rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--border);
  margin-top: 8rpx;
}

.servings-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.servings-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.servings-btn {
  width: 44rpx;
  height: 44rpx;
  background: #8B6344;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.servings-btn:active {
  opacity: 0.8;
}

.servings-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  min-width: 48rpx;
  text-align: center;
}

/* Ingredient display - compact */
.card .ingredient-row {
  padding: 8rpx 26rpx;
  margin-bottom: 8rpx;
  gap: 16rpx;
}

.card .ingredient-name {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--text-primary);
}

.card .ingredient-qty {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--text-primary);
  padding-right: 20rpx;
}

/* Step number - smaller size */
.step-number {
  width: 40rpx;
  height: 40rpx;
  font-size: 22rpx;
}

/* Image upload area */
.image-upload-area {
  width: 100%;
  height: 240rpx;
  border: 2rpx dashed var(--border);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface);
  overflow: hidden;
  position: relative;
}

.image-delete-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  z-index: 10;
}

.image-delete-btn:active {
  opacity: 0.8;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
}

/* Bottom action bar */
.action-bar {
  margin-bottom: 120rpx;
}

/* Source URL */
.source-link-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: var(--background);
  border-radius: 10rpx;
}

.source-link-row:active {
  opacity: 0.7;
}

.source-link-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-muted);
}

.source-url-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: var(--background);
  border-radius: 12rpx;
}

.source-url-card:active {
  opacity: 0.7;
}

.source-url-label {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
}

.copy-icon-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--background);
  border-radius: 12rpx;
  flex-shrink: 0;
}

.copy-icon-btn:active {
  opacity: 0.7;
}

/* Steps spacing */
.step-item {
  margin-bottom: 16rpx;
}

.step-item:last-child {
  margin-bottom: 0;
}

.source-url-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-muted);
  word-break: break-all;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.source-url {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  word-break: break-all;
  padding: 12rpx;
  background: var(--background);
  border-radius: 12rpx;
}
